# ─────────────────────────────────────────────
#  Veltrix – Environment Variables Example
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Flask secret key – change this to a long random string in production!
SECRET_KEY=your-super-secret-key-change-me

# Flask environment: development | production | testing
FLASK_ENV=development

# Flask debug mode (True/False)
FLASK_DEBUG=True

# Database URL
# Default: SQLite (stored in instance/database.db)
DATABASE_URL=sqlite:///database.db

# To switch to MySQL, replace with:
# DATABASE_URL=mysql+pymysql://username:password@localhost/veltrix_db
